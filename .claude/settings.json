{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/guard-destructive.mjs\"",
            "timeout": 10,
            "statusMessage": "Checking command for destructive operations..."
          }
        ]
      }
    ]
  }
}
